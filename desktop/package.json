{
  "name": "connect-ai-desktop",
  "version": "0.1.0",
  "description": "Connect AI — 자비스 같은 1인 기업 AI 비서 (데스크톱 앱, 비개발자용)",
  "main": "out/main.js",
  "author": "EZER AI",
  "license": "UNLICENSED",
  "repository": { "type": "git", "url": "https://github.com/wonseokjung/private_connectai.git" },
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc --noEmit -p .",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  },
  "build": {
    "appId": "ai.ezer.connect-desktop",
    "productName": "Connect AI",
    "directories": { "output": "release" },
    "files": ["out/**", "src/renderer/**", "assets/**", "package.json"],
    "mac": { "category": "public.app-category.productivity", "target": ["dmg"], "identity": null, "icon": "build/icon.icns" },
    "win": { "target": ["nsis"], "icon": "build/icon.ico" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true }
  }
}
